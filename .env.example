# ============================================================
# Jarvis V3 — Configuration
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter .env.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# "api" pour Anthropic/Mistral, "local" pour Ollama
LLM_PROVIDER=api

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Mistral ──────────────────────────────────────────────────
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# ── Ollama (local) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Serveur ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# "development" | "production"
ENVIRONMENT=development

# ── AISstream.io (navires temps réel) ─────────────────────────
# Clé gratuite sur https://aisstream.io
AISSTREAM_KEY=

# ── Localisation (météo proactive) ────────────────────────────
PROACTIVE_LAT=45.75
PROACTIVE_LON=4.85
PROACTIVE_CITY=Lyon

# ── TTS / STT ─────────────────────────────────────────────────
# "piper" (local) ou "elevenlabs"
TTS_PROVIDER=piper

# ElevenLabs (si TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_MODEL=eleven_flash_v2_5

# Whisper : "tiny" (80ms) | "small" (300ms) | "medium" (600ms)
WHISPER_MODEL=tiny

# ── LiveKit (pipeline vocal) ──────────────────────────────────
# Créer un projet sur cloud.livekit.io
LIVEKIT_URL=wss://ton-projet.livekit.cloud
LIVEKIT_API_KEY=APIxxx...
LIVEKIT_API_SECRET=xxx...

# ── Deepgram (STT Nova-2) ─────────────────────────────────────
# Compte gratuit : deepgram.com (200h/mois)
DEEPGRAM_API_KEY=xxx...

# ── Google Gemini (LLM) ───────────────────────────────────────
# Clé sur ai.google.dev
GOOGLE_API_KEY=xxx...

# ── Logging ───────────────────────────────────────────────────
# "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=DEBUG
